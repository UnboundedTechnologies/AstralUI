{
  "name": "@astralui/core",
  "version": "0.1.2",
  "description": "AstralUI - a self-contained, dependency-free React design system: theme engine (light/dark + per-brand theming), design tokens, and components (Modal, Drawer, Select, Menu, Toast, DateInput, PinInput, Spinner).",
  "license": "MIT",
  "author": "Unbounded Technologies",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnboundedTechnologies/AstralUI.git"
  },
  "homepage": "https://github.com/UnboundedTechnologies/AstralUI#readme",
  "bugs": {
    "url": "https://github.com/UnboundedTechnologies/AstralUI/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "design-system",
    "ui",
    "components",
    "theme",
    "dark-mode",
    "astralui"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tabler/icons-react": ">=3"
  },
  "dependencies": {
    "chroma-js": "^3.2.0"
  },
  "devDependencies": {
    "@tabler/icons-react": "^3.0.0",
    "@types/chroma-js": "^3.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
